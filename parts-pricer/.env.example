# Google Sheets (only needed when NOT using --dry-run)
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
SHEET_ID=

# eBay official API (only needed with --source api)
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_MARKETPLACE_ID=EBAY_US

# Scraper politeness (seconds). Higher = safer / less likely to be blocked.
SCRAPE_MIN_DELAY=3
SCRAPE_MAX_DELAY=6
